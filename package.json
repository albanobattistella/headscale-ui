{
  "name": "headscale-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --bun node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "bun --bun node_modules/vue-tsc/bin/vue-tsc.js -p tsconfig.app.json --noEmit && bun --bun node_modules/vite/bin/vite.js build",
    "preview": "bun --bun node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "lint": "bun --bun node_modules/@biomejs/biome/bin/biome check .",
    "format": "bun --bun node_modules/@biomejs/biome/bin/biome format --write .",
    "test": "bun test src",
    "test:e2e": "bun scripts/check-e2e-button-coverage.ts && bun --bun node_modules/vitest/vitest.mjs --config vitest.e2e.config.ts --run",
    "check": "bun run lint && bun run test && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "axios": "1.16.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-vue-next": "1.0.0",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "vue": "3.5.33",
    "vue-i18n": "11.4.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/vite": "4.2.4",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/browser-webdriverio": "^4.1.5",
    "@vue/tsconfig": "0.9.1",
    "fake-indexeddb": "^6",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vitest-browser-vue": "2.1.0",
    "vue-tsc": "3.2.7"
  }
}
